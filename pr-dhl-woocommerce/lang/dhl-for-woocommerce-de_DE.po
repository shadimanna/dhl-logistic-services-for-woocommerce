#. translators: %s: link to request a quote for becoming a DHL business customer
#: includes/class-pr-dhl-wc-method-paket.php:31
#, php-format
msgid "Below you will find all functions for controlling, preparing and processing your shipment with DHL Paket. Prerequisite is a valid DHL business customer contract. If you are not yet a DHL business customer, you can request a quote %1$shere%2$s."
msgstr "Nachfolgend finden Sie alle Funktionen zur Steuerung, Vorbereitung und Abwicklung Ihres Versands mit DHL Paket. Voraussetzung ist ein gültiger DHL-Geschäftskundenvertrag. Wenn Sie noch kein DHL-Geschäftskunde sind, können Sie %1$shier%2$s ein Angebot anfordern."

#: includes/class-pr-dhl-wc-method-paket.php:105
#: templates/checkout/dhl-preferred-services.php:128
#: build/pr-dhl-preferred-services-frontend.js:1
#: includes/checkout-blocks/dhl-preferred-services/block.js:391
msgid "None"
msgstr "Keine"

